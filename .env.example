# Coinbase CDP API Key pour Paymaster (gasless transactions)
NEXT_PUBLIC_CDP_API_KEY=your_coinbase_cdp_api_key_here

# OnchainKit Project ID
NEXT_PUBLIC_ONCHAINKIT_PROJECT_ID=your_onchainkit_project_id_here

# Base Network RPC URLs
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Lucky Draw Contract Address (à déployer)
NEXT_PUBLIC_LUCKY_DRAW_CONTRACT=0x...

# USDC Contract Address on Base
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# WalletConnect Project ID (optionnel)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
